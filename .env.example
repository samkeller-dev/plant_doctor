# Ollama endpoint (compose service name when running in docker, localhost otherwise)
OLLAMA_BASE_URL=http://ollama:11434

# Models pulled by the ollama init container at startup
OLLAMA_LLM_MODEL=mistral:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# Persistent Chroma collection
CHROMA_PERSIST_DIR=/app/chroma_db
CHROMA_COLLECTION=plant_doctor

# Corpus root inside the container
CORPUS_DIR=/app/corpus

# Off-topic guardrail: cosine similarity below this rejects the query.
# Range 0.0 - 1.0; lower = more permissive. Tune after smoke testing.
OFFTOPIC_SIM_THRESHOLD=0.35
